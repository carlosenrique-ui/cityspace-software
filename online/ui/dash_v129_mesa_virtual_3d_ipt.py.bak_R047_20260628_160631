import numpy as np
import pandas as pd
import dash
from dash import dcc, html, Input, Output, State, ctx
import plotly.graph_objects as go
from pathlib import Path

BASE = Path("/mnt/c/workspace/ipt-cityspace-engine/ipt_core_clean")
DATA = BASE / "globe_cityspace_open/projects/ipt_north_5000"

ROWS, COLS = 8, 16

def load_matrix(name):
    return pd.read_csv(DATA / name, sep=";", header=None).values.astype(float)

terrain = load_matrix("grid_terrain_m.csv")
building = load_matrix("grid_building_m.csv")
z_total = load_matrix("grid_z_total_m.csv")
target_cm = load_matrix("grid_pino_cm.csv")
uint8 = load_matrix("grid_uint8.csv")

path = []
for c in range(COLS):
    rr = range(ROWS) if c % 2 == 0 else range(ROWS - 1, -1, -1)
    for r in rr:
        path.append((r, c))

def build_mesh(z, active_rc=None):
    X=[]; Y=[]; Z=[]
    I=[]; J=[]; K=[]
    intensity=[]

    faces = [
        (0,1,2),(0,2,3),
        (4,5,6),(4,6,7),
        (0,1,5),(0,5,4),
        (1,2,6),(1,6,5),
        (2,3,7),(2,7,6),
        (3,0,4),(3,4,7),
    ]

    for r in range(ROWS):
        for c in range(COLS):
            h = float(z[r, c])
            if h <= 0:
                h = 0.03

            s = 0.82
            x0, x1 = c - s/2, c + s/2
            y0, y1 = r - s/2, r + s/2
            z0, z1 = 0, h

            base = len(X)
            verts = [
                (x0,y0,z0),(x1,y0,z0),(x1,y1,z0),(x0,y1,z0),
                (x0,y0,z1),(x1,y0,z1),(x1,y1,z1),(x0,y1,z1),
            ]

            for x,y,zz in verts:
                X.append(x); Y.append(y); Z.append(zz)
                intensity.append(h)

            for a,b,cidx in faces:
                I.append(base+a); J.append(base+b); K.append(base+cidx)

    return X,Y,Z,I,J,K,intensity

app = dash.Dash(__name__)
app.title = "Mesa Virtual 3D IPT"

app.layout = html.Div([
