    html.H2("Mesa Virtual 3D — IPT-CitySpace", style={"marginBottom":"4px"}),
    html.Div("128 pinos virtuais | trajetória ZigZag | BMP 0–255 → altura física 0–10 cm"),
    html.Br(),

    html.Div([
        html.Button("⏮ Backward", id="back"),
