@app.callback(
    Output("running","data"),
    Input("play","n_clicks"),
    Input("pause","n_clicks"),
    State("running","data"),
    prevent_initial_call=True
)
def set_running(play, pause, running):
    if ctx.triggered_id == "play":
        return True
    if ctx.triggered_id == "pause":
        return False
    return running

@app.callback(
    Output("direction","data"),
    Input("forward","n_clicks"),
    Input("back","n_clicks"),
    State("direction","data"),
    prevent_initial_call=True
)
def set_direction(fwd, back, direction):
    if ctx.triggered_id == "forward":
        return 1
    if ctx.triggered_id == "back":
        return -1
    return direction

@app.callback(
    Output("step","data"),
    Input("timer","n_intervals"),
    Input("reset","n_clicks"),
    Input("forward","n_clicks"),
    Input("back","n_clicks"),
    State("running","data"),
    State("direction","data"),
    State("speed","value"),
    State("step","data"),
)
def update_step(n, reset, fwd, back, running, direction, speed, step):
    trig = ctx.triggered_id
    step = int(step or 0)

    if trig == "reset":
        return 0

    if trig == "forward":
        return min(len(path)-1, step + 1)

    if trig == "back":
        return max(0, step - 1)

    if running:
        delta = max(1, int(speed or 1))
        return max(0, min(len(path)-1, step + int(direction) * delta))

    return step

@app.callback(
    Output("g3d","figure"),
    Output("info","children"),
    Input("step","data")
)
def draw(step):
    step = int(step or 0)

    z = np.zeros((ROWS, COLS), dtype=float)

    if step >= 0:
        for i in range(step + 1):
            r, c = path[i]
            z[r, c] = target_cm[r, c]

    r_active, c_active = path[step]
    active_h = max(float(z[r_active, c_active]), 0.03)

    X,Y,Z,I,J,K,intensity = build_mesh(z)

    fig = go.Figure()

    fig.add_trace(go.Mesh3d(
        x=X, y=Y, z=Z,
        i=I, j=J, k=K,
        intensity=intensity,
        colorscale="Turbo",
        cmin=0,
        cmax=10,
        opacity=1.0,
        colorbar=dict(title="Pino<br>cm"),
        lighting=dict(ambient=0.45, diffuse=0.8, specular=0.25),
        lightposition=dict(x=100, y=-100, z=200),
        name="Pinos"
    ))

    fig.add_trace(go.Scatter3d(
        x=[c_active],
        y=[r_active],
        z=[active_h + 0.6],
        mode="markers+text",
        marker=dict(size=8, color="red"),
        text=[f"P{step+1:03d}"],
        textposition="top center",
        name="Pino ativo"
    ))

    fig.update_layout(
        title="Mesa Virtual 3D — Método B: origem no canto superior direito, visão da esquerda para a direita",
        showlegend=False,
        scene=dict(
            xaxis=dict(title="Colunas", range=[-1, COLS]),
            yaxis=dict(title="Linhas", range=[ROWS, -1]),
            zaxis=dict(title="Altura do pino (cm)", range=[0, 11]),
            aspectratio=dict(x=2.75, y=1.35, z=0.82),
            camera=dict(
                eye=dict(x=3.45, y=-2.35, z=1.95),
                center=dict(x=-0.08, y=0.05, z=-0.03),
                up=dict(x=0, y=0, z=1)
            )
        ),
        margin=dict(l=0, r=0, t=40, b=0)
    )

    info = (
        f"Pino ativo: P{step+1:03d} | linha={r_active} coluna={c_active} | "
        f"terreno_m={terrain[r_active,c_active]:.3f} | "
        f"edificio_m={building[r_active,c_active]:.3f} | "
        f"z_total_m={z_total[r_active,c_active]:.3f} | "
        f"pino_cm={target_cm[r_active,c_active]:.3f} | "
        f"BMP={int(uint8[r_active,c_active])}"
    )

    return fig, info

