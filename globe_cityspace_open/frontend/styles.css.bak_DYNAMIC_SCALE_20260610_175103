html, body, #cesiumContainer {
  width: 100%;
  height: 100%;
  margin: 0;
  padding: 0;
  overflow: hidden;
  font-family: Arial, sans-serif;
}

#topbar {
  position: absolute;
  z-index: 10;
  top: 12px;
  left: 12px;
  right: 12px;
  min-height: 52px;
  background: rgba(5, 15, 25, 0.92);
  color: white;
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 14px;
  border-radius: 10px;
  flex-wrap: wrap;
}

#topbar strong {
  white-space: nowrap;
}

#citySelect,
#scaleSelect {
  background: #0f172a;
  color: white;
  border: 1px solid #334155;
  border-radius: 8px;
  padding: 9px;
}

button {
  background: #0ea5e9;
  color: white;
  border: 0;
  padding: 10px 14px;
  border-radius: 8px;
  cursor: pointer;
  font-weight: 600;
}

button:hover {
  background: #0284c7;
}

#createArea {
  background: #22c55e;
}

#createArea:hover {
  background: #16a34a;
}

#exportGrid {
  background: #2563eb;
}

#exportGrid:hover {
  background: #1d4ed8;
}

#coordPanel {
  position: absolute;
  z-index: 10;
  right: 12px;
  bottom: 24px;
  width: 360px;
  background: rgba(5, 15, 25, 0.92);
  color: white;
  padding: 14px;
  border-radius: 10px;
  line-height: 1.45;
  font-size: 14px;
}

#coordInfo {
  color: #cbd5e1;
  margin-top: 8px;
}

#infoPanel {
  position: absolute;
  z-index: 10;
  left: 12px;
  bottom: 24px;
  width: 380px;
  background: rgba(5, 15, 25, 0.92);
  color: white;
  padding: 14px;
  border-radius: 10px;
  line-height: 1.45;
  font-size: 14px;
}

#areaInfo {
  color: #cbd5e1;
  margin-top: 8px;
}

#coordPanel hr {
  border: 0;
  border-top: 1px solid #334155;
  margin: 10px 0;
}

#cursorInfo {
  color: #93c5fd;
  margin-top: 6px;
}

#helpPanel {
  position: absolute;
  z-index: 10;
  right: 12px;
  top: 92px;
  width: 360px;
  background: rgba(5, 15, 25, 0.86);
  color: white;
  padding: 14px;
  border-radius: 10px;
  line-height: 1.45;
  font-size: 13px;
}

#clearArea {
  background: #ef4444;
}

#clearArea:hover {
  background: #dc2626;
}

#exportSpatialProject {
  background: #9333ea;
}

#exportSpatialProject:hover {
  background: #7e22ce;
}
