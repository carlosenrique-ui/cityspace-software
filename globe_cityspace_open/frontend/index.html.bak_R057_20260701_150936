<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <title>Globe-CitySpace</title>
  <script src="https://cesium.com/downloads/cesiumjs/releases/1.122/Build/Cesium/Cesium.js"></script>
  <link href="https://cesium.com/downloads/cesiumjs/releases/1.122/Build/Cesium/Widgets/widgets.css" rel="stylesheet">
  <link href="styles.css" rel="stylesheet">
</head>
<body>
  <div id="topbar">
    <strong>Globe-CitySpace</strong>
<button id="uxMenuToggle">☰ MENU</button>

    <span>Origem:</span>
<select id="originMode">
  <option value="city" selected>Cidade</option>
  <option value="latlon">Lat/Lon</option>
  <option value="click">Clique no Globo</option>
</select>
<select id="citySelect">
      <option value="bertioga">Bertioga</option>
      <option value="cubatao">Cubatão</option>
      <option value="santos">Santos</option>
      <option value="sjc">São José dos Campos</option>
      <option value="sao_paulo">São Paulo</option>
      <option value="sorocaba">Sorocaba</option>
      <option value="ipt">IPT - Demo</option>
    </select>

    <button id="openCity">Abrir cidade</button>
<span style="margin-left:12px;">Lat:</span>
<input id="gotoLat" type="text" inputmode="decimal" step="0.000001" value="-23.556794" style="width:110px;">
<span>Lon:</span>
<input id="gotoLon" type="text" inputmode="decimal" step="0.000001" value="-46.737329" style="width:110px;">
<button id="gotoLatLon">Ir para Lat/Lon</button>


    <button id="viewTop">Vista topo</button>
    <button id="viewOblique">Vista oblíqua</button>
    <button id="viewNorth">Norte</button>
<button id="toggleEsriBase">Base ESRI</button>
<button id="toggleOsmBase">Base OSM</button>

    <button id="enablePickPoint">Clique no Globo</button>

    <select id="scaleSelect">
      <option value="500">1:500</option>
      <option value="1000">1:1000</option>
      <option value="2500">1:2500</option>
      <option value="5000" selected>1:5000</option>
      <option value="10000">1:10000</option>
    </select>

    <button id="createArea">Gerar Área CitySpace</button>
    <button id="clearArea">Limpar Área/Grid</button>
    <button id="exportGrid">Exportar Grid JSON</button>
    <button id="exportSpatialProject">Gerar Spatial Project</button>
    <button id="openProjectionMapping">Projeção Mapeada</button>
  </div>

  
<div id="uxSideMenu">
  <div class="ux-title">MENU</div>

  <div class="ux-section">
    <div class="ux-heading">Visualização</div>
    <div id="uxViewSlot"></div>
  </div>

  <div class="ux-section">
    <div class="ux-heading">Camadas</div>
    <div id="uxLayerSlot"></div>
  </div>

  <div class="ux-section">
    <div class="ux-heading">CitySpace</div>
    <div id="uxCitySpaceSlot"></div>
  </div>

  <div class="ux-section">
    <div class="ux-heading">Exportação</div>
    <div id="uxExportSlot"></div>
  </div>
</div>


  <div id="coordPanel">
    <strong>Ponto de Referência</strong>
    <div id="coordInfo">
      Use “Abrir cidade”, navegue e depois clique em “Clique no Globo”.
    </div>
    <hr>
    <strong>Cursor</strong>
    <div id="cursorInfo">Lat/Lon: --</div>
  </div>

  <div id="helpPanel">
    <strong>Navegação</strong><br>
    Mouse esquerdo: mover<br>
    Scroll: zoom<br>
    Mouse direito / Ctrl + mouse: girar e inclinar<br>
    
  </div>

  <div id="infoPanel">
    <strong>Área CitySpace</strong>
    <div id="areaInfo">Nenhuma área criada.</div>
  </div>

  <div id="scalePanel">
    <strong>Escala dinâmica</strong>
    <div class="scale-bar-wrap">
      <div id="dynamicScaleBar"></div>
    </div>
    <div id="dynamicScaleText">--</div>
    <div id="cameraScaleInfo">Altitude: -- | Escala aprox.: --</div>
  </div>

  <div id="cesiumContainer"></div>

  <script src="main.js"></script>
<script>
document.getElementById("openProjectionMapping").addEventListener("click", function () {
  window.location.href = "http://127.0.0.1:8050";
});
</script>
</body>
</html>
