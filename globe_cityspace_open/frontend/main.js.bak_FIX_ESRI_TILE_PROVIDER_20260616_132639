// =========================================
// SPRINT G — ESCALA DINÂMICA
// Barra de escala aproximada conforme zoom/câmera.
// =========================================
function formatDistance(meters) {
  if (!isFinite(meters) || meters <= 0) return "--";
  if (meters >= 1000) {
    return (meters / 1000).toFixed(meters >= 10000 ? 0 : 1) + " km";
  }
  return meters.toFixed(meters >= 100 ? 0 : 1) + " m";
}

function niceDistance(meters) {
  if (!isFinite(meters) || meters <= 0) return 0;

  const powers = [1, 2, 5];
  const exponent = Math.floor(Math.log10(meters));
  const base = Math.pow(10, exponent);

  let best = base;
  for (const p of powers) {
    const candidate = p * base;
    if (candidate <= meters) best = candidate;
  }
  return best;
}

function updateDynamicScale() {
  const bar = document.getElementById("dynamicScaleBar");
  const text = document.getElementById("dynamicScaleText");
  const camInfo = document.getElementById("cameraScaleInfo");
  if (!bar || !text || !camInfo) return;

  const scene = viewer.scene;
  const canvas = scene.canvas;

  const y = Math.floor(canvas.clientHeight * 0.82);
  const x1 = Math.floor(canvas.clientWidth * 0.18);
  const x2 = x1 + 100;

  const ray1 = viewer.camera.getPickRay(new Cesium.Cartesian2(x1, y));
  const ray2 = viewer.camera.getPickRay(new Cesium.Cartesian2(x2, y));

  const p1 = scene.globe.pick(ray1, scene);
  const p2 = scene.globe.pick(ray2, scene);

  if (!p1 || !p2) return;

  const c1 = Cesium.Cartographic.fromCartesian(p1);
  const c2 = Cesium.Cartographic.fromCartesian(p2);

  const geodesic = new Cesium.EllipsoidGeodesic(c1, c2);
  const metersPer100px = geodesic.surfaceDistance;

  const nice = niceDistance(metersPer100px);
  const px = Math.max(40, Math.min(160, 100 * nice / metersPer100px));

  bar.style.width = px.toFixed(0) + "px";
  text.textContent = formatDistance(nice);

  const altitude = viewer.camera.positionCartographic.height;
  const approxScale = Math.max(1, Math.round(altitude * 2.5));

  camInfo.textContent =
    "Altitude: " + formatDistance(altitude) +
    " | Escala aprox.: 1:" + approxScale.toLocaleString("pt-BR");
}

viewer.scene.postRender.addEventListener(updateDynamicScale);
window.addEventListener("load", function () {
  setTimeout(updateDynamicScale, 500);
});

/* PATCH ÚNICO — IPT-DEMO ENVELOPE LIMPO 16x8 */
(function () {
  const CONFIG = {
    rotationDeg: 33.18,
    cellM: 31.25,
    cols: 16,
    rows: 8,
    lineWidth: 2
  };

  window.drawRotatedIptGrid = function(centerLat, centerLon, widthM, heightM, angleDeg) {
    clearGrid();

    const width = CONFIG.cols * CONFIG.cellM;
    const height = CONFIG.rows * CONFIG.cellM;
    const x0 = -width / 2.0;
    const y0 = -height / 2.0;

    function p(x, y) {
      const r = rotateXY(x, y, CONFIG.rotationDeg);
      return metersOffsetToLonLat(centerLat, centerLon, r.x, r.y);
    }

    const allPts = [];

    for (let c = 0; c <= CONFIG.cols; c++) {
      const x = x0 + c * CONFIG.cellM;
      const p1 = p(x, y0);
      const p2 = p(x, y0 + height);
      allPts.push(p1, p2);

      gridEntities.push(viewer.entities.add({
        polyline: {
          positions: Cesium.Cartesian3.fromDegreesArray([
            p1.lon, p1.lat,
            p2.lon, p2.lat
          ]),
          width: CONFIG.lineWidth,
          material: Cesium.Color.BLUE
        }
      }));
    }

    for (let r = 0; r <= CONFIG.rows; r++) {
      const y = y0 + r * CONFIG.cellM;
      const p1 = p(x0, y);
      const p2 = p(x0 + width, y);
      allPts.push(p1, p2);

      gridEntities.push(viewer.entities.add({
        polyline: {
          positions: Cesium.Cartesian3.fromDegreesArray([
            p1.lon, p1.lat,
            p2.lon, p2.lat
          ]),
          width: CONFIG.lineWidth,
          material: Cesium.Color.BLUE
        }
      }));
    }

    const west = Math.min(...allPts.map(q => q.lon));
    const east = Math.max(...allPts.map(q => q.lon));
    const south = Math.min(...allPts.map(q => q.lat));
    const north = Math.max(...allPts.map(q => q.lat));

    return { west, south, east, north };
  };

  window.IPT_ENVELOPE_FINAL_CONFIG = CONFIG;
})();


