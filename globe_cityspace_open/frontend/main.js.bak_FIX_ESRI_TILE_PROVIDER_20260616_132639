}

function computeIptRealDimensions() {
  const scale = parseInt(document.getElementById("scaleSelect").value, 10);

  const surveyHeightM = 709.3251438132108;
  const cellSizeM = surveyHeightM / TABLE_ROWS;
  const gridWidthM = cellSizeM * TABLE_COLS;
  const gridHeightM = cellSizeM * TABLE_ROWS;

  if (scale === 8867) {
    return {
      scale: 8867,
      cellMode: "1×1 cm",
      tableWidthCm: 16,
      tableHeightCm: 8,
      cellSizeM,
      widthM: gridWidthM,
      heightM: gridHeightM,
      rotationDeg: 33.18
    };
  }

  if (scale === 4433) {
    return {
      scale: 4433,
      cellMode: "2×2 cm",
      tableWidthCm: 32,
      tableHeightCm: 16,
      cellSizeM,
      widthM: gridWidthM,
      heightM: gridHeightM,
      rotationDeg: 33.18
    };
  }

  return null;
}

function createIptDemoGrid() {
  const city = cities.ipt;
  const dims = computeIptRealDimensions();
  if (!dims) return;

  setReferencePoint(
    `${city.name} - Centroide`,
    city.centerLat,
    city.centerLon
  );

  const delta = metersToDegrees(
    city.centerLat,
    dims.widthM,
    dims.heightM
  );

  const west = city.centerLon - delta.dLon / 2;
  const east = city.centerLon + delta.dLon / 2;
  const south = city.centerLat - delta.dLat / 2;
  const north = city.centerLat + delta.dLat / 2;

  if (areaEntity) {
    viewer.entities.remove(areaEntity);
  }

  const iptRectangle = Cesium.Rectangle.fromDegrees(west, south, east, north);

  areaEntity = viewer.entities.add({
    rectangle: {
      coordinates: iptRectangle,
      material: Cesium.Color.YELLOW.withAlpha(0.12),
      outline: true,
      outlineColor: Cesium.Color.YELLOW
    }
  });

  viewer.camera.flyTo({
    destination: iptRectangle,
    duration: 1.2
  });

  currentGrid = {
    west,
    south,
    east,
    north,
    scale: dims.scale,
    widthM: dims.widthM,
    heightM: dims.heightM,
    centerLat: city.centerLat,
    centerLon: city.centerLon,
    cellMode: dims.cellMode
  };

  const iptGridBounds = drawRotatedIptGrid(
    city.centerLat,
    city.centerLon,
    dims.widthM,
    dims.heightM,
    dims.rotationDeg
  );

  if (iptGridBounds) {
    const iptGridRectangle = Cesium.Rectangle.fromDegrees(
      iptGridBounds.west,
      iptGridBounds.south,
      iptGridBounds.east,
      iptGridBounds.north
    );

    viewer.camera.flyTo({
      destination: iptGridRectangle,
      duration: 1.2
    });
  }

  document.getElementById("areaInfo").innerHTML = `
    <b>IPT Demo North-Up</b><br>
    Grid real 16×8 gerado para a demonstração IPT.<br>
    Modo físico: ${dims.cellMode}<br>
    Escala cartográfica: 1:${dims.scale}<br>
    Mesa: ${dims.tableWidthCm} cm × ${dims.tableHeightCm} cm<br>
    Grid científico: ${dims.widthM.toFixed(1)} m × ${dims.heightM.toFixed(1)} m<br>
    Célula quadrada: ${dims.cellSizeM.toFixed(2)} m × ${dims.cellSizeM.toFixed(2)} m<br>
