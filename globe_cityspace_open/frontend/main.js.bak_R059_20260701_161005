/* PATCH — NOMINATIM REVERSE GEOCODING LAT/LON -> LOCAL */
async function reverseGeocodeNominatim(lat, lon) {
  const url =
    "https://nominatim.openstreetmap.org/reverse?format=jsonv2" +
    "&lat=" + encodeURIComponent(lat) +
    "&lon=" + encodeURIComponent(lon) +
    "&zoom=18&addressdetails=1";

  try {
    const resp = await fetch(url, {
      headers: {
        "Accept": "application/json"
      }
    });

    if (!resp.ok) {
      throw new Error("HTTP " + resp.status);
    }

    const data = await resp.json();
    const a = data.address || {};

    const country = a.country || "";
    const state = a.state || a.region || "";
    const city =
      a.city ||
      a.town ||
      a.village ||
      a.municipality ||
      a.county ||
      "";
    const neighbourhood =
      a.neighbourhood ||
      a.suburb ||
      a.quarter ||
      a.city_district ||
      a.hamlet ||
      "";

    const road = a.road || a.pedestrian || a.footway || "";
    const display = data.display_name || "";

    return {
      country,
      state,
      city,
      neighbourhood,
      road,
      display
    };
  } catch (err) {
    console.warn("Falha no Nominatim:", err);
    return null;
  }
}

function updateReferencePanelWithGeocode(name, lat, lon, geo) {
  let html = "";

  html += (name || "Ponto de referência") + "<br>";

  if (geo) {
    if (geo.country) html += "País: " + geo.country + "<br>";
    if (geo.state) html += "Estado/Região: " + geo.state + "<br>";
    if (geo.city) html += "Cidade: " + geo.city + "<br>";
    if (geo.neighbourhood) html += "Bairro/Setor: " + geo.neighbourhood + "<br>";
    if (geo.road) html += "Via: " + geo.road + "<br>";
  } else {
    html += "Localidade: não identificada pelo Nominatim<br>";
  }

  html += "Lat: " + lat.toFixed(7) + "<br>";
  html += "Lon: " + lon.toFixed(7);

