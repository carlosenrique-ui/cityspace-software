/* R052 — parser robusto de coordenadas.
   Aceita:
   -23.55
   -23,55
   -23,55, -46,73
   -23.55, -46.73
*/
function parseCoordinateInput(value) {
  if (value === null || value === undefined) return NaN;
  return parseFloat(
    String(value)
      .trim()
      .replace(",", ".")
      .replace(/[^\d\.\-+]/g, "")
  );
}

function parseLatLonPair(text) {
  const raw = String(text || "").trim();

  // Caso com separador ; recomendado para vírgula decimal: -23,55; -46,73
  if (raw.includes(";")) {
    const parts = raw.split(";").map(x => x.trim()).filter(Boolean);
    return {
      lat: parseCoordinateInput(parts[0]),
      lon: parseCoordinateInput(parts[1])
    };
  }

  // Caso com ponto decimal: -23.55, -46.73
  const mDot = raw.match(/(-?\d+(?:\.\d+)?)\s*,\s*(-?\d+(?:\.\d+)?)/);
  if (mDot) {
    return {
      lat: parseCoordinateInput(mDot[1]),
      lon: parseCoordinateInput(mDot[2])
    };
  }

  // Caso com vírgula decimal e espaço entre coordenadas: -23,55 -46,73
  const mComma = raw.match(/(-?\d+,\d+)\s+(-?\d+,\d+)/);
  if (mComma) {
    return {
      lat: parseCoordinateInput(mComma[1]),
      lon: parseCoordinateInput(mComma[2])
    };
  }

  return { lat: NaN, lon: NaN };
}


