/* R057 — elimina a tela inicial "suja" no modo demo IPT */

function hideUiForIptDemo() {
  if (!isIptDemoUrl()) return;

  [
    "#toolbar",
    "#leftPanel",
    "#menuPanel",
    "#floatingMenu",
    "#statusBar"
  ].forEach(sel => {
    const el = document.querySelector(sel);
    if (el) el.style.display = "none";
  });

  document.body.style.background = "black";
}

function showUiAfterIptDemo() {
  [
    "#toolbar",
    "#leftPanel",
    "#menuPanel",
    "#floatingMenu",
    "#statusBar"
  ].forEach(sel => {
    const el = document.querySelector(sel);
    if (el) el.style.display = "";
  });
}

if (typeof isIptDemoUrl === "function" && isIptDemoUrl()) {
  hideUiForIptDemo();

  window.addEventListener("load", () => {
    setTimeout(() => {
      if (typeof startIptCinematicIntro === "function") {
        startIptCinematicIntro();
      }

      setTimeout(() => {
        showUiAfterIptDemo();
      }, 7000);
    }, 100);
  });
}




/* R058 — remove máscara demo após globo estar pronto */
(function () {
  if (typeof isIptDemoUrl !== "function" || !isIptDemoUrl()) return;

  let removed = false;

  function releaseDemoMask() {
    if (removed) return;
    removed = true;
    try {
      document.documentElement.classList.remove("ipt-demo-loading");
    } catch (e) {}
  }

  try {
    viewer.scene.globe.tileLoadProgressEvent.addEventListener(function(count) {
      if (count === 0) {
        setTimeout(releaseDemoMask, 800);
      }
    });
  } catch (e) {}

  // fallback seguro
  setTimeout(releaseDemoMask, 4500);
})();
