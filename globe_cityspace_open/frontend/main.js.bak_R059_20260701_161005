function computeIptRealDimensions() {
  const scale = parseInt(document.getElementById("scaleSelect").value, 10);

  const surveyHeightM = 709.3251438132108;
  const cellSizeM = surveyHeightM / TABLE_ROWS;
  const gridWidthM = cellSizeM * TABLE_COLS;
  const gridHeightM = cellSizeM * TABLE_ROWS;

  if (scale === 8867) {
    return {
      scale: 8867,
      cellMode: "1×1 cm",
      tableWidthCm: 16,
      tableHeightCm: 8,
      cellSizeM,
      widthM: gridWidthM,
      heightM: gridHeightM,
      rotationDeg: 33.18
    };
  }

  if (scale === 4433) {
    return {
      scale: 4433,
      cellMode: "2×2 cm",
      tableWidthCm: 32,
      tableHeightCm: 16,
      cellSizeM,
      widthM: gridWidthM,
      heightM: gridHeightM,
      rotationDeg: 33.18
    };
  }

  return null;
}

