function metersToDegrees(lat, widthM, heightM) {
  const metersPerDegreeLat = 111320;
  const metersPerDegreeLon =
    111320 * Math.cos(Cesium.Math.toRadians(lat));

  return {
    dLat: (heightM / 2) / metersPerDegreeLat,
    dLon: (widthM / 2) / metersPerDegreeLon
  };
}

function computeRealDimensions(scale) {
  const tableWidthCm = TABLE_COLS * CELL_CM;
  const tableHeightCm = TABLE_ROWS * CELL_CM;

  const widthM = (tableWidthCm / 100) * scale;
  const heightM = (tableHeightCm / 100) * scale;

  return {
    tableWidthCm,
    tableHeightCm,
    widthM,
    heightM
  };
}


function metersOffsetToLonLat(centerLat, centerLon, dxM, dyM) {
  const earthRadiusM = 6378137.0;
  const dLat = (dyM / earthRadiusM) * (180.0 / Math.PI);
  const dLon = (dxM / (earthRadiusM * Math.cos(centerLat * Math.PI / 180.0))) * (180.0 / Math.PI);
  return {
    lon: centerLon + dLon,
    lat: centerLat + dLat
  };
}

function rotateXY(x, y, angleDeg) {
  const a = angleDeg * Math.PI / 180.0;
  const ca = Math.cos(a);
  const sa = Math.sin(a);
  return {
    x: x * ca - y * sa,
    y: x * sa + y * ca
  };
}

function drawRotatedIptGrid(centerLat, centerLon, widthM, heightM, angleDeg) {
  clearGrid();

  const x0 = -widthM / 2.0;
  const y0 = -heightM / 2.0;
  const dx = widthM / TABLE_COLS;
  const dy = heightM / TABLE_ROWS;

  function p(x, y) {
    const r = rotateXY(x, y, angleDeg);
    return metersOffsetToLonLat(centerLat, centerLon, r.x, r.y);
  }

  const allPts = [];

  // linhas verticais do grid local
  for (let c = 0; c <= TABLE_COLS; c++) {
    const x = x0 + c * dx;
    const p1 = p(x, y0);
    const p2 = p(x, y0 + heightM);
    allPts.push(p1, p2);

    gridEntities.push(viewer.entities.add({
      polyline: {
        positions: Cesium.Cartesian3.fromDegreesArray([p1.lon, p1.lat, p2.lon, p2.lat]),
        width: 2,
        material: Cesium.Color.RED
      }
    }));
  }

  // linhas horizontais do grid local
  for (let r = 0; r <= TABLE_ROWS; r++) {
    const y = y0 + r * dy;
    const p1 = p(x0, y);
    const p2 = p(x0 + widthM, y);
    allPts.push(p1, p2);

    gridEntities.push(viewer.entities.add({
      polyline: {
        positions: Cesium.Cartesian3.fromDegreesArray([p1.lon, p1.lat, p2.lon, p2.lat]),
        width: 2,
        material: Cesium.Color.RED
      }
    }));
  }

  // centroides e labels
  for (let r = 0; r < TABLE_ROWS; r++) {
    for (let c = 0; c < TABLE_COLS; c++) {
      const cellNumber = r * TABLE_COLS + c + 1;
      const cellId = "P" + String(cellNumber).padStart(3, "0");
      const cx = x0 + (c + 0.5) * dx;
      const cy = y0 + heightM - (r + 0.5) * dy;
      const pp = p(cx, cy);
      allPts.push(pp);

      // Tela 1 limpa: não desenha pinos nem labels.
}
  }
}


function drawGrid(west, south, east, north) {
  clearGrid();

  const dLon = (east - west) / TABLE_COLS;
  const dLat = (north - south) / TABLE_ROWS;

  for (let c = 0; c <= TABLE_COLS; c++) {
    const lon = west + c * dLon;

    gridEntities.push(
      viewer.entities.add({
        polyline: {
          positions: Cesium.Cartesian3.fromDegreesArray([
            lon, south,
            lon, north
          ]),
          width: 1,
          material: Cesium.Color.RED
        }
      })
    );
  }

  for (let r = 0; r <= TABLE_ROWS; r++) {
    const lat = south + r * dLat;

    gridEntities.push(
      viewer.entities.add({
        polyline: {
          positions: Cesium.Cartesian3.fromDegreesArray([
            west, lat,
            east, lat
          ]),
          width: 1,
          material: Cesium.Color.RED
        }
      })
    );
  }

  for (let r = 0; r < TABLE_ROWS; r++) {
    for (let c = 0; c < TABLE_COLS; c++) {
      const cellNumber = r * TABLE_COLS + c + 1;
      const cellId = "P" + String(cellNumber).padStart(3, "0");

      const centerLon = west + (c + 0.5) * dLon;
      const centerLat = north - (r + 0.5) * dLat;

      gridEntities.push(
        viewer.entities.add({
          position: Cesium.Cartesian3.fromDegrees(centerLon, centerLat, 0),
          label: {
            text: cellId,
            font: "11px sans-serif",
            fillColor: Cesium.Color.WHITE,
            outlineColor: Cesium.Color.BLACK,
            outlineWidth: 3,
            style: Cesium.LabelStyle.FILL_AND_OUTLINE,
            horizontalOrigin: Cesium.HorizontalOrigin.CENTER,
            verticalOrigin: Cesium.VerticalOrigin.CENTER,
            disableDepthTestDistance: Number.POSITIVE_INFINITY
          }
        })
      );
    }
  }
}

