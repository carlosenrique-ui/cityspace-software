}

async function enrichCurrentPointWithNominatim(sourceName, lat, lon) {
  const geo = await reverseGeocodeNominatim(lat, lon);

  let label = sourceName || "Lat/Lon manual";

  if (geo) {
    const parts = [];
    if (geo.city) parts.push(geo.city);
    if (geo.state) parts.push(geo.state);
    if (geo.country) parts.push(geo.country);
    if (parts.length > 0) {
