    }
    const R = 6378137.0;
    return {
      lon: centerLon + (dxM / (R * Math.cos(centerLat * Math.PI / 180))) * 180 / Math.PI,
      lat: centerLat + (dyM / R) * 180 / Math.PI
    };
  }

  function rotateXYLocal(x, y, deg) {
    const a = deg * Math.PI / 180;
    return { x: x*Math.cos(a) - y*Math.sin(a), y: x*Math.sin(a) + y*Math.cos(a) };
  }

  function drawRotatedExploratoryGrid(centerLat, centerLon, widthM, heightM, angleDeg) {
    clearGrid();

    const x0 = -widthM / 2;
    const y0 = -heightM / 2;
    const dx = widthM / TABLE_COLS;
    const dy = heightM / TABLE_ROWS;
    const allPts = [];

    function p(x, y) {
      const r = rotateXYLocal(x, y, angleDeg);
      return metersOffset(centerLat, centerLon, r.x, r.y);
    }

    for (let c = 0; c <= TABLE_COLS; c++) {
      const x = x0 + c * dx;
      const p1 = p(x, y0);
      const p2 = p(x, y0 + heightM);
      allPts.push(p1, p2);
      gridEntities.push(viewer.entities.add({
        polyline: {
          positions: Cesium.Cartesian3.fromDegreesArray([p1.lon, p1.lat, p2.lon, p2.lat]),
          width: 2,
          material: Cesium.Color.RED
        }
      }));
    }

    for (let r = 0; r <= TABLE_ROWS; r++) {
      const y = y0 + r * dy;
      const p1 = p(x0, y);
      const p2 = p(x0 + widthM, y);
      allPts.push(p1, p2);
      gridEntities.push(viewer.entities.add({
        polyline: {
          positions: Cesium.Cartesian3.fromDegreesArray([p1.lon, p1.lat, p2.lon, p2.lat]),
          width: 2,
          material: Cesium.Color.RED
        }
      }));
    }

    for (let r = 0; r < TABLE_ROWS; r++) {
      for (let c = 0; c < TABLE_COLS; c++) {
        const cellNumber = (c % 2 === 0)
          ? c * TABLE_ROWS + r + 1
          : c * TABLE_ROWS + (TABLE_ROWS - r);

        const cellId = "P" + String(cellNumber).padStart(3, "0");
        const cx = x0 + (c + 0.5) * dx;
        const cy = y0 + heightM - (r + 0.5) * dy;
        const pp = p(cx, cy);

        gridEntities.push(viewer.entities.add({
          position: Cesium.Cartesian3.fromDegrees(pp.lon, pp.lat, 0),
          label: {
            text: cellId,
            font: "11px sans-serif",
            fillColor: Cesium.Color.WHITE,
            outlineColor: Cesium.Color.BLACK,
            outlineWidth: 3,
            style: Cesium.LabelStyle.FILL_AND_OUTLINE,
            horizontalOrigin: Cesium.HorizontalOrigin.CENTER,
            verticalOrigin: Cesium.VerticalOrigin.CENTER,
            disableDepthTestDistance: Number.POSITIVE_INFINITY
          }
        }));
      }
    }

    return {
      west: Math.min(...allPts.map(q => q.lon)),
      east: Math.max(...allPts.map(q => q.lon)),
      south: Math.min(...allPts.map(q => q.lat)),
      north: Math.max(...allPts.map(q => q.lat))
    };
  }

