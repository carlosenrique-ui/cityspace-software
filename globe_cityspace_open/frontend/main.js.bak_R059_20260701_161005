  function refreshContext() {

    if (isIptMode()) {
      activateIptMode();
    } else {

      const city = el("citySelect");

      if (city && city.value === "sao_paulo") {

        try {
          if (typeof openSelectedCity === "function") {
            openSelectedCity();
          }
        } catch(e){}

      }

      activateExploratoryMode();
    }
  }

  window.addEventListener("load", function(){

    const city = el("citySelect");
    const project = el("projectSelect");
    const origin = el("originMode");

    if (city) {
      city.addEventListener("change", refreshContext, true);
    }

    if (project) {
      project.addEventListener("change", refreshContext, true);
    }

    if (origin) {
      origin.addEventListener("change", refreshContext, true);
    }

    setTimeout(refreshContext, 1000);
  });

})();

/* R052B — garantir Cubatão no menu de cidades */
function ensureCubataoOption() {
  const sel = document.getElementById("citySelect");
  if (!sel) return;

  let found = false;
  for (const opt of sel.options) {
    if (opt.value === "cubatao") found = true;
  }

  if (!found) {
    const opt = document.createElement("option");
    opt.value = "cubatao";
    opt.textContent = "Cubatão";
    sel.appendChild(opt);
  }
}

setTimeout(ensureCubataoOption, 300);
